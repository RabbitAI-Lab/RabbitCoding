{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Rabbit Coding",
  "version": "0.1.0",
  "identifier": "com.rabbitai-lab.coding",
  "build": {
    "beforeDevCommand": "pnpm setup:runtime && pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "RabbitCoding",
        "width": 800,
        "height": 600,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      },
      {
        "label": "pet",
        "title": "Rabbit Pet",
        "url": "index.html?window=pet",
        "width": 320,
        "height": 280,
        "decorations": false,
        "transparent": true,
        "resizable": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "shadow": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "resources/sidecar",
      "resources/node-runtime",
      "resources/silero_vad.onnx"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": "Entitlements.plist"
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["rabbitcoding"]
      }
    },
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/RabbitAI-Lab/RabbitCoding/releases/download/nightly/latest.json"
      ],
      "dialog": true,
      "pubkey": "RWRbtrfue8ftTvhEm+yZRekI9JITEy2cIMTzCHYNOxYtChKV+BeXNcoK"
    }
  }
}
